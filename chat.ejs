<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>AI Chat</title>
</head>
<body>
    <h1>اسأل Zakerly AI 🤖</h1>
    <input type="text" id="ques" placeholder="اكتب سؤالك هنا..." style="width:70%; padding:10px;">
    <button onclick="ask()">إرسال</button>
    <div id="res" style="margin-top:20px; font-weight:bold; color: blue;"></div>

    <script>
        async function ask() {
            const q = document.getElementById('ques').value;
            const resDiv = document.getElementById('res');
            resDiv.innerText = "جاري التفكير...";
            
            const response = await fetch('/ai-chat?token=<%= token %>', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'question=' + encodeURIComponent(q)
            });
            const text = await response.text();
            resDiv.innerText = text;
        }
